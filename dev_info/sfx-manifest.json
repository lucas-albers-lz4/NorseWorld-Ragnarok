{
  "masters": {
    "song_menu": "sfx-src/song_menu.ogg",
    "song_land": "sfx-src/song_land.ogg",
    "ambient_generic": "sfx-src/ambient_generic.ogg",
    "ambient_cave": "sfx-src/ambient_cave.ogg",
    "ambient_water": "sfx-src/ambient_water.ogg",
    "ui_click": "sfx-src/ui_click.ogg",
    "ui_system": "sfx-src/ui_system.ogg",
    "ui_door_open": "sfx-src/ui_door_open.ogg",
    "ui_door_close": "sfx-src/ui_door_close.ogg",
    "ui_positive": "sfx-src/ui_positive.ogg",
    "ui_negative": "sfx-src/ui_negative.ogg",
    "ui_self": "sfx-src/ui_self.ogg",
    "combat_hit": "sfx-src/combat_hit.ogg",
    "combat_move": "sfx-src/combat_move.ogg",
    "combat_ranged": "sfx-src/combat_ranged.ogg",
    "item_generic": "sfx-src/item_generic.ogg",
    "spell_generic": "sfx-src/spell_generic.ogg",
    "faith_fanfare": "sfx-src/faith_fanfare.ogg"
  },
  "rules": [
    {"glob": "songs/startup.ogg", "master": "song_menu"},
    {"glob": "songs/intro.ogg", "master": "song_menu"},
    {"glob": "songs/*.ogg", "master": "song_land"},
    {"glob": "ambient/bgCave.ogg", "master": "ambient_cave"},
    {"glob": "ambient/bgCrypt.ogg", "master": "ambient_cave"},
    {"glob": "ambient/bgGrynrHalls.ogg", "master": "ambient_cave"},
    {"glob": "ambient/bgUnderWater.ogg", "master": "ambient_water"},
    {"glob": "ambient/bgWater.ogg", "master": "ambient_water"},
    {"glob": "ambient/*.ogg", "master": "ambient_generic"},
    {"glob": "buttonY.ogg", "master": "ui_click"},
    {"glob": "knowledges.ogg", "master": "ui_click"},
    {"glob": "skills.ogg", "master": "ui_click"},
    {"glob": "game_*.ogg", "master": "ui_system"},
    {"glob": "pay.ogg", "master": "ui_system"},
    {"glob": "pack.ogg", "master": "ui_system"},
    {"glob": "doorOpen.ogg", "master": "ui_door_open"},
    {"glob": "doorClose.ogg", "master": "ui_door_close"},
    {"glob": "victory.ogg", "master": "ui_positive"},
    {"glob": "levelUp.ogg", "master": "ui_positive"},
    {"glob": "game_new.ogg", "master": "ui_positive"},
    {"glob": "defeat.ogg", "master": "ui_negative"},
    {"glob": "quit.ogg", "master": "ui_negative"},
    {"glob": "self.ogg", "master": "ui_self"},
    {"glob": "map.ogg", "master": "ui_click"},
    {"glob": "effects/*.ogg", "master": "spell_generic"},
    {"glob": "faith/*.ogg", "master": "faith_fanfare"},
    {"glob": "creatures/*.ogg", "master": "combat_hit"},
    {"glob": "items/*.ogg", "master": "item_generic"}
  ],
  "creature_actions": {
    "Attack": "combat_hit",
    "Wounded": "combat_hit",
    "Killed": "combat_hit",
    "Move": "combat_move",
    "Shot": "combat_ranged",
    "Slay": "combat_ranged"
  },
  "item_master": "item_generic"
}
